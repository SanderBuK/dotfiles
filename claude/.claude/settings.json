{
  "permissions": {
    "allow": [
      "Read(**)",
      "Read(*)",
      "Read(~/**)",
      "Read(/tmp/**)",
      "Read(/etc/**)",
      "Glob(*)",
      "Grep(*)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(more *)",
      "Bash(find *)",
      "Bash(locate *)",
      "Bash(tree *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(ack *)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(column *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(id)",
      "Bash(date)",
      "Bash(uname *)",
      "Bash(uptime)",
      "Bash(ps *)",
      "Bash(tar -t *)",
      "Bash(tar --list *)",
      "Bash(unzip -l *)",
      "Bash(zipinfo *)",
      "Bash(md5sum *)",
      "Bash(sha256sum *)",
      "Bash(shasum *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git ls-files *)",
      "Bash(git describe *)",
      "Bash(gh repo view *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh api *)",
      "Bash(docker ps *)",
      "Bash(docker images *)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(docker version)",
      "Bash(docker info)",
      "Bash(npm --version)",
      "Bash(npm list *)",
      "Bash(npm ls *)",
      "Bash(npm view *)",
      "Bash(npm outdated *)",
      "Bash(yarn --version)",
      "Bash(yarn list *)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip --version)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(bd *)",
      "Bash(~/.claude/plugins/cache/claude-plugins-official/superpowers/*/skills/brainstorming/scripts/start-server.sh *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/auto-allow-safe-bash.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.config/tmux/scripts/claude-notify.sh clear"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.config/tmux/scripts/claude-notify.sh clear"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.config/tmux/scripts/claude-notify.sh set"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.config/tmux/scripts/claude-notify.sh set"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ~/.config/tmux/scripts/claude-notify.sh clear"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "voiceEnabled": true
}
